# Host user/group used by docker-compose services so mounted ./data and ./logs stay writable.
PUID=1000
PGID=1000

# Host directories mounted into worker/web/sqlite-web containers.
HOST_DATA_DIR=./data
HOST_LOGS_DIR=./logs

# Independent SQLite databases inside the worker/web containers.
# If the server has no old database files, keep these defaults; the app creates them automatically.
DATA_DIR=data
BASE_DB_PATH=data/base_data.db
SCORING_DB_PATH=data/scoring.db
TRADING_DB_PATH=data/trading.db
MARKET_DB_PATH=data/market.db

# Database opened by the sqlite-web container. Change to /data/scoring.db,
# /data/trading.db, or /data/market.db when you want to inspect another module DB.
SQLITE_WEB_DB_PATH=/data/base_data.db

BINANCE_TESTNET=true
BINANCE_TESTNET_API_KEY=YOUR_TESTNET_API_KEY
BINANCE_TESTNET_SECRET_KEY=YOUR_TESTNET_SECRET_KEY
BINANCE_REAL_API_KEY=YOUR_REAL_API_KEY
BINANCE_REAL_API_SECRET=YOUR_REAL_API_SECRET
